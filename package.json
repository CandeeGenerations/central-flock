{
  "name": "central-flock",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:hash": "npx tsx scripts/hash-password.ts",
    "build": "tsc -b && vite build",
    "consolidate-dbs": "tsx scripts/consolidate-dbs.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "concurrently \"vite\" \"tsx watch --import ./server/lib/sentry.ts server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --import ./server/lib/sentry.ts server/index.ts",
    "eslint": "tsc -b && tsc -p tsconfig.server.json && eslint .",
    "prepare": "husky",
    "prettier": "prettier --cache --check --write --ignore-unknown .",
    "prettier:ci": "pnpm exec prettier --check .",
    "preview": "vite preview",
    "release": "standard-version -a -- --release-as minor"
  },
  "dependencies": {
