# Authentication (optional — leave unset for local use without auth)
# Generate a hashed password: pnpm auth:hash
# AUTH_PASSWORD_HASH=
# JWT_SECRET=
# JWT_EXPIRY=7d
# API_KEY=
# ANTHROPIC_API_KEY=

# Shared secret for cgen-api → Central Flock internal webhooks (/webhooks/*)
# CENTRAL_FLOCK_INTERNAL_SECRET=
