# Template for .env.deploy. Copy this file to .env.deploy and fill in real
# values. The real file is gitignored; do not commit secrets.
#
# Why this exists: husky's post-commit/post-merge hooks fire deploy.sh, which
# needs pnpm/node on PATH and Sentry build vars in the environment. GUI git
# clients (GitHub Desktop, Tower) launch with a stripped env that doesn't
# load ~/.zshrc, so the hooks source this file to get the env they need.

# PATH preamble — bootstrap Homebrew then let fnm pick the active Node.
export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env)"
fi

# Sentry build-time secrets (runtime DSN lives in the launchd plist).
export SENTRY_AUTH_TOKEN="sntrys_..."
export SENTRY_ORG="your-org-slug"
export VITE_SENTRY_DSN="https://...@oXXXX.ingest.us.sentry.io/XXXX"
